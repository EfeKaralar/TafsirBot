# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# "anthropic" uses Claude Sonnet; "openai" uses GPT-4o
LLM_PROVIDER=anthropic

# ── Embeddings ────────────────────────────────────────────────────────────────
# Do not change this after the first upsert — mixing models breaks the collection
EMBEDDING_MODEL=text-embedding-3-large

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=tafsir

# ── Postgres ──────────────────────────────────────────────────────────────────
# Docker container init settings and local app connection settings.
# When running Python scripts on your host machine, use POSTGRES_HOST=localhost.
# If a future app runs inside docker-compose, it should use POSTGRES_HOST=postgres.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tafsir_bot
POSTGRES_USER=tafsirbot
POSTGRES_PASSWORD=tafsirbot_dev_password
POSTGRES_SSLMODE=prefer
POSTGRES_CONNECT_TIMEOUT=5

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Path to sources/quran-json/dist/ relative to repo root
QURAN_JSON_DIST=sources/quran-json/dist

# ── Audit ─────────────────────────────────────────────────────────────────────
# Cosine score below this is flagged as low-confidence
AUDIT_SCORE_THRESHOLD=0.70
