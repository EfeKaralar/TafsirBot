# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# "anthropic" uses Claude Sonnet; "openai" uses GPT-4o
LLM_PROVIDER=anthropic

# ── Embeddings ────────────────────────────────────────────────────────────────
# Do not change this after the first upsert — mixing models breaks the collection
EMBEDDING_MODEL=text-embedding-3-large

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=tafsir

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=tafsir_bot
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Path to sources/quran-json/dist/ relative to repo root
QURAN_JSON_DIST=sources/quran-json/dist

# ── Audit ─────────────────────────────────────────────────────────────────────
# Cosine score below this is flagged as low-confidence
AUDIT_SCORE_THRESHOLD=0.70
